{
  "name": "@chatpanel/bridge",
  "version": "0.10.17",
  "type": "module",
  "description": "Local bridge that exposes the AI coding agents installed on your machine — Claude Code (CLI), Codex (CLI), and Antigravity CLI (formerly Gemini CLI, which remains available for business/enterprise) — to the ChatPanel Chrome extension over a localhost SSE endpoint. Bring your own agent.",
  "keywords": [
    "chatpanel",
    "claude-code",
    "codex",
    "antigravity-cli",
    "gemini-cli",
    "chrome-extension",
    "ai-agents",
    "bridge"
  ],
  "homepage": "https://chatpanel.net",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chatpanel/chatpanel-bridge.git"
  },
  "license": "SEE LICENSE IN LICENSE",
  "bin": {
    "chatpanel-bridge": "src/server.js"
  },
  "files": [
    "src",
    "scripts",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test tests/*.test.mjs",
    "build:bin": "bash scripts/build-binaries.sh"
  },
  "dependencies": {},
  "optionalDependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  }
}
